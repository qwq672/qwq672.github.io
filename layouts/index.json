[
  {{ range $index, $page := (where .Site.RegularPages "Section" "posts") }}
  {{ if $index }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
    "summary": {{ $page.Summary | jsonify }}
  }
  {{ end }}
]
