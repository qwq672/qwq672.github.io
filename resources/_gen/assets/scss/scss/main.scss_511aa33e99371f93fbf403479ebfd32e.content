@charset "UTF-8";*{margin:0;padding:0;box-sizing:border-box}body{background-color:#fff6ea;color:#3b2a1f;font-family:system-ui,-apple-system,segoe ui,Roboto,noto sans,sans-serif;line-height:1.65;font-size:1.05rem}a{text-decoration:none;color:inherit}img{max-width:100%;display:block}ul,ol{list-style:none}button,input,textarea{font:inherit}*{margin:0;padding:0;box-sizing:border-box}body{background-color:#fff6ea;color:#3b2a1f;font-family:system-ui,-apple-system,segoe ui,Roboto,noto sans,sans-serif;font-size:1.05rem;line-height:1.65}.main-container{max-width:860px;margin:0 auto;padding:2rem 1.5rem}h1,.page-title{font-size:2rem;margin-bottom:1rem;font-weight:550}h2,.section-title{font-size:1.6rem;margin:2rem 0 1rem;font-weight:500}h3{font-size:1.3rem;margin:1rem 0 .5rem;font-weight:500}a{color:#e67e22;text-decoration:none;transition:color .2s ease}a:hover{color:#f5a97f}.site-header{background:#fffaf2;border-bottom:1px solid #f0e4d0;position:sticky;top:0;z-index:10}.nav-container{max-width:860px;margin:0 auto;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap}.logo a{font-weight:600;font-size:1.35rem;color:#e67e22}.nav-menu{display:flex;gap:1rem;list-style:none}.nav-menu a{color:#3b2a1f;padding:.5rem 0}.nav-menu a:hover{color:#f5a97f}@media(max-width:640px){.nav-menu{display:none;width:100%;flex-direction:column;align-items:center;margin-top:1rem}.nav-menu.active{display:flex}.menu-toggle{display:block;background:0 0;border:none;font-size:1.8rem;cursor:pointer}}@media(min-width:641px){.menu-toggle{display:none}}.post-card{background:#fffef7;border-radius:20px;overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,5%),0 1px 2px rgba(0,0,0,3%);transition:all .25s ease;margin-bottom:2rem;display:flex;flex-direction:column}.post-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,8%)}.post-card__image-link{display:block;line-height:0}.post-card__image{width:100%;height:240px;object-fit:cover;display:block}.post-card__content{padding:1rem}.post-card__title{font-size:1.4rem;margin-bottom:.5rem}.post-card__title a{color:#3b2a1f}.post-card__title a:hover{color:#f5a97f}.post-card__summary{color:#6b5a4e;font-size:.95rem;margin-bottom:.5rem}.post-card__meta{font-size:.85rem;color:#6b5a4e;border-top:1px solid #f0e4d0;padding-top:.5rem;margin-top:.5rem}.posts-grid{display:grid;grid-template-columns:1fr;gap:2rem}@media(min-width:640px){.posts-grid{grid-template-columns:repeat(2,1fr)}}.article-content{line-height:1.75;font-size:1rem;color:#3b2a1f;margin:2rem 0}.article-content img{max-width:100%;height:auto;border-radius:12px;margin:1rem 0;display:block}.article-content p{margin-bottom:1rem}.article-content pre,.article-content code{background:#f4efe7;border-radius:10px;font-size:.9rem}.article-content pre{padding:1rem;overflow-x:auto}.article-content blockquote{border-left:4px solid #f5a97f;padding-left:1rem;color:#6b5a4e;font-style:italic}.article-content hr{border:none;height:1px;background:#f0e4d0;margin:2rem 0}#nprogress{pointer-events:none}#nprogress .bar{background:#f5a97f;position:fixed;z-index:1031;top:0;left:0;width:100%;height:3px}#nprogress .peg{display:block;position:absolute;right:0;width:100px;height:100%;box-shadow:0 0 10px #f5a97f,0 0 5px #f5a97f;opacity:1;transform:rotate(3deg)translate(0,-4px)}.toast-container{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);z-index:1050;pointer-events:none}.toast-container .toast-message{background-color:#fffaf2;color:#3b2a1f;padding:1rem 2rem;border-radius:12px;box-shadow:0 4px 12px rgba(0,0,0,.1);font-size:.875rem;border:1px solid #f0e4d0;pointer-events:auto;backdrop-filter:none;display:flex;align-items:center;gap:1rem;animation:fadeInUp .3s ease}.toast-container .toast-message .close-toast{cursor:pointer;margin-left:1rem;font-weight:700;color:#9b8a7a}.toast-container .toast-message .close-toast:hover{color:#f5a97f}@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}